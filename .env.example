# AI Pulse 环境变量配置
# 复制本文件为 .env 后填入实际值（.env 已被 .gitignore 忽略，不会入库）
# Windows / PowerShell:  cp .env.example .env

# ── GitHub API Token（可选但推荐）──────────────────────
# 作用：提升 GitHub API 限流 60 → 5000 次/小时
# 生成：https://github.com/settings/tokens （只需默认 public 只读权限即可）
GITHUB_TOKEN=

# ── 阶段二智能化所需（尚未启用，此处预留）──────────────
# 接国内大模型做摘要/去重归并/主题聚类/情感热度
# AGNES_API_KEY=
# AGNES_BASE_URL=
# AGNES_MODEL=
