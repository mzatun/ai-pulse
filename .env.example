# AI Pulse 环境变量配置
# 复制本文件为 .env 后填入实际值（.env 已被 .gitignore 忽略，不会入库）
# Windows / PowerShell:  cp .env.example .env

# ── GitHub API Token（可选但推荐）──────────────────────
# 作用：提升 GitHub API 限流 60 → 5000 次/小时
# 生成：https://github.com/settings/tokens （只需 default public 只读权限即可）
GITHUB_TOKEN=

# ── 阶段二智能化（LLM 摘要 / 聚类 / 情感 / 每日速报）────
# 国内大模型 agnes AI（OpenAI 兼容接口）
# 未配置 AGNES_API_KEY 时，自动走规则降级，站点照常构建不崩
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash
AGNES_API_KEY=
